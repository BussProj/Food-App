# ==============================================================================
# ENVIRONMENT VARIABLES TEMPLATE (SaaS PLATFORM)
# ==============================================================================
# Copy this file to '.env' before running development containers.
# Do NOT commit raw secrets or production passwords to version control.

# 1. Django System Configuration
DJANGO_SECRET_KEY=dev_django_secret_key_change_me_in_production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,*.platform.local
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# 2. PostgreSQL Configuration
POSTGRES_DB=restaurant_platform
POSTGRES_USER=platform_admin
POSTGRES_PASSWORD=secure_postgres_developer_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=20

# 3. Redis Channels & Cache Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1

# 4. Authentication Secrets
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
OTP_EXPIRY_SECONDS=300
OTP_RETRIES_MAX=5

# 5. SRE Logging & Observability
LOG_LEVEL=INFO
CORRELATION_ID_HEADER=X-Correlation-ID
OPENTELEMETRY_EXPORTER_OTLP_ENDPOINT=http://collector:4317

# 6. External Integrations (Mocks in Development)
SMS_GATEWAY_API_KEY=mock_sms_gateway_api_key_placeholder
PAYMENT_GATEWAY_MERCHANT_ID=mock_payment_merchant_id_placeholder
PARTNER_DELIVERY_API_KEY=mock_partner_delivery_key_placeholder
